{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["dan1elhughes"],
  "pruneStaleBranches": true,
  "recreateClosed": true,
  "dependencyDashboard": false,
  "fetchChangeLogs": "off",
  "toolSettings": {
    "nodeMaxMemory": 4096
  },
  // Lidarr Docker tags include a legacy `0.8.1.2135` tag.
  // Renovate misinterprets this as `8.1.2135`, which appears newer than v3.x.
  // This explicitly blocks that tag to prevent incorrect upgrade PRs.
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/linuxserver/lidarr"],
      "allowedVersions": "!/^8\\.1\\.2135$/"
    },
    // predbat_addon publishes variant-prefixed tags (e.g. `slim-v8.42.1`,
    // `alpine-v8.42.1`, `v8.42.1`). Pin Renovate to the `slim-v` track and
    // teach it to parse the semver that follows the prefix.
    {
      "matchPackageNames": ["nipar44/predbat_addon"],
      "versioning": "regex:^slim-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}
